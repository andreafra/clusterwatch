package model

import "time"

type TenantInfo struct {
	ID         string   `json:"id"`
	Name       string   `json:"name"`
	Context    string   `json:"context"`
	AWSProfile string   `json:"awsProfile"`
	Namespaces []string `json:"namespaces"`
}

type ResourceCounts struct {
	Namespaces  int `json:"namespaces"`
	Nodes       int `json:"nodes"`
	Pods        int `json:"pods"`
	Deployments int `json:"deployments"`
}

type ClusterSnapshot struct {
	TenantID       string         `json:"tenantId"`
	TenantName     string         `json:"tenantName"`
	Context        string         `json:"context"`
	AWSProfile     string         `json:"awsProfile"`
	Connection     string         `json:"connection"`
	Message        string         `json:"message"`
	ResourceCounts ResourceCounts `json:"resourceCounts"`
	UpdatedAt      time.Time      `json:"updatedAt"`
}

type ClusterInventory struct {
	TenantID   string               `json:"tenantId"`
	TenantName string               `json:"tenantName"`
	Context    string               `json:"context"`
	AWSProfile string               `json:"awsProfile"`
	Namespaces []NamespaceInventory `json:"namespaces"`
	UpdatedAt  time.Time            `json:"updatedAt"`
}

type NamespaceInventory struct {
	Name            string              `json:"name"`
	Phase           string              `json:"phase"`
	Age             string              `json:"age"`
	PodCount        int                 `json:"podCount"`
	ReadyPods       int                 `json:"readyPods"`
	ProblemPods     int                 `json:"problemPods"`
	RestartCount    int                 `json:"restartCount"`
	ServiceCount    int                 `json:"serviceCount"`
	IngressCount    int                 `json:"ingressCount"`
	ConfigMapCount  int                 `json:"configMapCount"`
	SecretCount     int                 `json:"secretCount"`
	Pods            []PodInventory      `json:"pods"`
	Services        []ServiceInventory  `json:"services"`
	Ingresses       []IngressInventory  `json:"ingresses"`
	ConfigMaps      []ConfigMapInventory `json:"configMaps"`
	Secrets         []SecretInventory   `json:"secrets"`
}

type PodInventory struct {
	Name            string               `json:"name"`
	Phase           string               `json:"phase"`
	Reason          string               `json:"reason"`
	Message         string               `json:"message"`
	ReadyContainers int                  `json:"readyContainers"`
	ContainerCount  int                  `json:"containerCount"`
	RestartCount    int                  `json:"restartCount"`
	Age             string               `json:"age"`
	NodeName        string               `json:"nodeName"`
	PodIP           string               `json:"podIp"`
	OwnerKind       string               `json:"ownerKind"`
	OwnerName       string               `json:"ownerName"`
	QOSClass        string               `json:"qosClass"`
	Containers      []ContainerInventory `json:"containers"`
}

type ContainerInventory struct {
	Name           string `json:"name"`
	Image          string `json:"image"`
	Ready          bool   `json:"ready"`
	RestartCount   int32  `json:"restartCount"`
	State          string `json:"state"`
	StateReason    string `json:"stateReason"`
	LastExitCode   int32  `json:"lastExitCode"`
	RequestsCPU    string `json:"requestsCpu"`
	RequestsMemory string `json:"requestsMemory"`
	LimitsCPU      string `json:"limitsCpu"`
	LimitsMemory   string `json:"limitsMemory"`
}

type ServiceInventory struct {
	Name         string   `json:"name"`
	Type         string   `json:"type"`
	ClusterIP    string   `json:"clusterIp"`
	ExternalIP   string   `json:"externalIp"`
	Ports        []string `json:"ports"`
	Selector     bool     `json:"selector"`
	Age          string   `json:"age"`
}

type IngressInventory struct {
	Name       string   `json:"name"`
	ClassName  string   `json:"className"`
	Hosts      []string `json:"hosts"`
	Paths      []string `json:"paths"`
	Targets    []string `json:"targets"`
	Address    string   `json:"address"`
	TLSEnabled bool     `json:"tlsEnabled"`
	Age        string   `json:"age"`
}

type ConfigMapInventory struct {
	Name      string `json:"name"`
	DataKeys  int    `json:"dataKeys"`
	BinaryKeys int   `json:"binaryKeys"`
	Age       string `json:"age"`
}

type SecretInventory struct {
	Name     string `json:"name"`
	Type     string `json:"type"`
	DataKeys int    `json:"dataKeys"`
	Age      string `json:"age"`
}

type Event struct {
	Type      string    `json:"type"`
	TenantID  string    `json:"tenantId,omitempty"`
	Timestamp time.Time `json:"timestamp"`
	Payload   any       `json:"payload"`
}
